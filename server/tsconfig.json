{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "moduleResolution": "NodeNext",

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules"]
}